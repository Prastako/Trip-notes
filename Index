<!DOCTYPE html>

<html lang="cs">
<head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<meta content="#fdf8f0" media="(prefers-color-scheme: light)" name="theme-color"/>
<meta content="#131110" media="(prefers-color-scheme: dark)" name="theme-color"/>
<title>Cestovní poznámky · Jan Rajmont · 2026</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700;900&amp;family=Cormorant+Garamond:wght@400;600&amp;display=swap" rel="stylesheet"/>
<style>
:root {
  --bg:#131110; --surface:#1c1916; --surface2:#26221e; --surface3:#322d28;
  --ink:#f0e8dc; --ink2:#b0a090; --ink3:#6e5e50; --ink4:#3e3028;
  --jp:#e89898; --jp-t:rgba(232,152,152,.09); --jp-b:rgba(232,152,152,.2);
  --vn:#78cc8a; --vn-t:rgba(120,204,138,.09); --vn-b:rgba(120,204,138,.2);
  --tw:#7aaee8; --tw-t:rgba(122,174,232,.09); --tw-b:rgba(122,174,232,.2);
  --warn:#e8c878; --warn-t:rgba(232,200,120,.09); --warn-b:rgba(232,200,120,.22);
  --red:#e87878; --red-t:rgba(232,120,120,.09); --red-b:rgba(232,120,120,.22);
  --border:rgba(255,255,255,.07); --border2:rgba(255,255,255,.13);
}
@media(prefers-color-scheme:light){
  :root{
    --bg:#f4ede0; --surface:#fdf8f0; --surface2:#ece4d4; --surface3:#e2d9c8;
    --ink:#1c1410; --ink2:#6b5c48; --ink3:#a8937a; --ink4:#d4c4aa;
    --jp:#8a1a1a; --jp-t:rgba(138,26,26,.07); --jp-b:rgba(138,26,26,.2);
    --vn:#1a6b2a; --vn-t:rgba(26,107,42,.07); --vn-b:rgba(26,107,42,.2);
    --tw:#1a4a8a; --tw-t:rgba(26,74,138,.07); --tw-b:rgba(26,74,138,.2);
    --warn:#7a5a00; --warn-t:rgba(122,90,0,.06); --warn-b:rgba(122,90,0,.2);
    --red:#8a1a1a; --red-t:rgba(138,26,26,.06); --red-b:rgba(138,26,26,.2);
    --border:rgba(28,20,16,.08); --border2:rgba(28,20,16,.17);
  }
}
*{box-sizing:border-box;margin:0;padding:0;}
::-webkit-scrollbar{width:3px;}
::-webkit-scrollbar-thumb{background:var(--surface3);border-radius:3px;}
body{background:var(--bg);color:var(--ink);font-family:'DM Sans',sans-serif;line-height:1.6;min-height:100vh;}

/* ── LAYOUT ── */
.page{max-width:720px;margin:0 auto;padding:40px 20px 80px;}

/* ── HEADER ── */
.header{text-align:center;padding:32px 0 40px;border-bottom:1px solid var(–border2);margin-bottom:40px;}
.header-orn{font-size:.64rem;font-weight:900;color:var(–ink3);opacity:.45;letter-spacing:.1em;margin-bottom:12px;}
.header-title{font-family:‘Cormorant Garamond’,serif;font-size:2.2rem;font-weight:600;color:var(–ink);line-height:1.2;}
.header-title em{color:var(–ink3);font-style:normal;}
.header-sub{margin-top:10px;font-size:.72rem;font-weight:700;letter-spacing:.15em;text-transform:uppercase;color:var(–ink3);}
.header-dates{margin-top:6px;font-size:.82rem;color:var(–ink2);}
.header-orn-bot{font-size:.64rem;font-weight:900;color:var(–ink3);opacity:.35;margin-top:14px;transform:rotate(180deg);display:block;}

/* ── SECTION ── */
.section{margin-bottom:12px;}
details.section{border-radius:14px;overflow:hidden;}
details.section[open]{margin-bottom:24px;}
details.section > summary{list-style:none;cursor:pointer;-webkit-user-select:none;user-select:none;}
details.section > summary::-webkit-details-marker{display:none;}
details.section > summary:focus-visible{outline:none;}
.section-header{display:flex;align-items:center;gap:12px;padding:14px 16px;background:var(–surface);border:1px solid var(–border2);border-radius:14px;transition:background .15s;}
details.section[open] > summary .section-header{border-radius:14px 14px 0 0;border-bottom-color:transparent;}
details.section > summary:active .section-header{background:var(–surface2);}
.section-dot{width:6px;height:6px;border-radius:50%;flex-shrink:0;}
.dot-jp{background:var(–jp);}
.dot-vn{background:var(–vn);}
.dot-tw{background:var(–tw);}
.dot-warn{background:var(–warn);}
.dot-neu{background:var(–ink3);}
.section-title{font-family:‘Cormorant Garamond’,serif;font-size:1.4rem;font-weight:600;color:var(–ink);flex:1;}
.section-flag{font-size:.95rem;}
.section-arrow{font-size:.62rem;font-weight:900;color:var(–ink4);transition:transform .22s cubic-bezier(.4,0,.2,1);flex-shrink:0;}
details.section[open] .section-arrow{transform:rotate(180deg);}
.section-body{padding:16px;background:var(–surface);border:1px solid var(–border2);border-top:none;border-radius:0 0 14px 14px;}
.section-div{display:none;}

/* ── SUBSECTION (nested collapsible) ── */
details.subsection{margin-top:12px;border-radius:10px;overflow:hidden;}
details.subsection[open]{margin-bottom:4px;}
details.subsection > summary{list-style:none;cursor:pointer;-webkit-user-select:none;user-select:none;}
details.subsection > summary::-webkit-details-marker{display:none;}
details.subsection > summary:focus-visible{outline:none;}
.subsection-header{display:flex;align-items:center;gap:10px;padding:10px 14px;background:var(–surface2);border:1px solid var(–border2);border-radius:10px;transition:background .15s;}
details.subsection[open] > summary .subsection-header{border-radius:10px 10px 0 0;border-bottom-color:transparent;}
details.subsection > summary:active .subsection-header{background:var(–surface3);}
.subsection-title{font-family:‘DM Sans’,sans-serif;font-size:.78rem;font-weight:700;letter-spacing:.06em;text-transform:uppercase;color:var(–ink2);flex:1;}
.subsection-body{padding:14px;background:var(–surface2);border:1px solid var(–border2);border-top:none;border-radius:0 0 10px 10px;}
details.subsection[open] .section-arrow{transform:rotate(180deg);}

/* ── TIMELINE ── */
.timeline{display:flex;flex-direction:column;gap:4px;}
.tl-item{display:flex;gap:14px;align-items:baseline;padding:7px 0;border-bottom:1px solid var(–border);}
.tl-item:last-child{border-bottom:none;}
.tl-date{font-size:.66rem;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(–ink3);flex-shrink:0;width:72px;}
.tl-content{font-size:.84rem;color:var(–ink2);flex:1;}
.tl-content strong{color:var(–ink);font-weight:600;}
.tl-tag{font-size:.57rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;padding:2px 7px;border-radius:20px;flex-shrink:0;align-self:center;}
.tag-jp{background:var(–jp-t);border:1px solid var(–jp-b);color:var(–jp);}
.tag-tw{background:var(–tw-t);border:1px solid var(–tw-b);color:var(–tw);}
.tag-vn{background:var(–vn-t);border:1px solid var(–vn-b);color:var(–vn);}
.tag-warn{background:var(–warn-t);border:1px solid var(–warn-b);color:var(–warn);}
.tag-red{background:var(–red-t);border:1px solid var(–red-b);color:var(–red);}

/* ── CARDS GRID ── */
.cards{display:grid;grid-template-columns:1fr 1fr;gap:10px;}
@media(max-width:480px){.cards{grid-template-columns:1fr;}}
.card{background:var(–surface);border:1px solid var(–border2);border-radius:14px;padding:14px 16px;position:relative;overflow:hidden;}
.card::before{content:’꧁’;position:absolute;top:7px;left:9px;font-size:.62rem;font-weight:900;color:var(–ink4);line-height:1;}
.card::after{content:’꧂’;position:absolute;bottom:7px;right:9px;font-size:.62rem;font-weight:900;color:var(–ink4);line-height:1;}
.card.jp{border-color:var(–jp-b);background:var(–jp-t);}
.card.tw{border-color:var(–tw-b);background:var(–tw-t);}
.card.vn{border-color:var(–vn-b);background:var(–vn-t);}
.card.warn{border-color:var(–warn-b);background:var(–warn-t);}
.card-label{font-size:.57rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(–ink3);margin-bottom:6px;}
.card-title{font-family:‘Cormorant Garamond’,serif;font-size:1.05rem;font-weight:600;color:var(–ink);margin-bottom:4px;}
.card-body{font-size:.78rem;color:var(–ink2);line-height:1.55;}
.card-body strong{color:var(–ink);font-weight:600;}
.card-body em{color:var(–ink3);font-style:normal;font-size:.74rem;}

/* ── LIST ── */
.note-list{display:flex;flex-direction:column;gap:6px;}
.note-item{background:var(–surface);border:1px solid var(–border);border-radius:10px;padding:10px 14px;font-size:.82rem;color:var(–ink2);}
.note-item strong{color:var(–ink);font-weight:600;}
.note-item.warn{border-color:var(–warn-b);background:var(–warn-t);}
.note-item.red{border-color:var(–red-b);background:var(–red-t);}
.note-item.jp{border-left:3px solid var(–jp);padding-left:12px;}
.note-item.tw{border-left:3px solid var(–tw);padding-left:12px;}
.note-item.vn{border-left:3px solid var(–vn);padding-left:12px;}

/* ── ROUTE STOPS ── */
.stops{display:flex;flex-direction:column;gap:0;}
.stop{display:flex;gap:14px;}
.stop-line{display:flex;flex-direction:column;align-items:center;flex-shrink:0;width:20px;}
.stop-dot{width:10px;height:10px;border-radius:50%;border:2px solid var(–ink3);background:var(–bg);flex-shrink:0;margin-top:3px;}
.stop-dot.filled{background:var(–ink3);}
.stop-dot.jp{border-color:var(–jp);background:var(–jp-t);}
.stop-dot.tw{border-color:var(–tw);background:var(–tw-t);}
.stop-dot.vn{border-color:var(–vn);background:var(–vn-t);}
.stop-connector{flex:1;width:1px;background:var(–border2);margin:2px 0;}
.stop-content{padding:0 0 20px 0;flex:1;}
.stop-place{font-weight:700;color:var(–ink);font-size:.9rem;}
.stop-days{font-size:.66rem;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(–ink3);margin-left:6px;}
.stop-notes{font-size:.78rem;color:var(–ink2);margin-top:3px;line-height:1.5;}

/* ── ACCOM TABLE ── */
.accom{display:flex;flex-direction:column;gap:6px;}
.accom-row{display:flex;gap:10px;align-items:start;background:var(–surface);border:1px solid var(–border);border-radius:10px;padding:10px 14px;}
.accom-flag{font-size:1.1rem;flex-shrink:0;margin-top:1px;}
.accom-info{flex:1;}
.accom-name{font-weight:600;color:var(–ink);font-size:.84rem;}
.accom-detail{font-size:.74rem;color:var(–ink2);margin-top:2px;}
.accom-price{font-size:.78rem;font-weight:700;color:var(–ink3);flex-shrink:0;text-align:right;}
.accom-row.missing{border-style:dashed;opacity:.55;}

/* ── CHECKLIST ── */
.checklist{display:grid;grid-template-columns:1fr 1fr;gap:6px;}
@media(max-width:420px){.checklist{grid-template-columns:1fr;}}
.check-item{background:var(–surface);border:1px solid var(–border);border-radius:9px;padding:8px 12px;font-size:.78rem;color:var(–ink2);display:flex;align-items:center;gap:8px;}
.check-item::before{content:‘○’;font-size:.7rem;color:var(–ink4);flex-shrink:0;}
.check-item strong{color:var(–ink);}

/* ── CONTACTS ── */
.contacts{display:flex;flex-direction:column;gap:6px;}
.contact-row{display:flex;justify-content:space-between;align-items:center;padding:9px 14px;background:var(–surface);border:1px solid var(–border);border-radius:10px;}
.contact-name{font-size:.82rem;color:var(–ink);}
.contact-sub{font-size:.7rem;color:var(–ink3);margin-top:1px;}
.contact-num{font-size:.78rem;font-weight:700;color:var(–ink2);font-variant-numeric:tabular-nums;letter-spacing:.02em;}

/* ── CITY SUBSECTION ── */
.city-block{margin-bottom:24px;}
.city-block:last-child{margin-bottom:0;}
.city-heading{display:flex;align-items:center;gap:10px;margin-bottom:12px;padding-bottom:8px;border-bottom:1px solid var(–border2);}
.city-flag{font-size:1rem;}
.city-name{font-family:‘Cormorant Garamond’,serif;font-size:1.15rem;font-weight:600;color:var(–ink);}
.city-context{font-size:.78rem;color:var(–ink2);line-height:1.6;margin-bottom:14px;padding:10px 14px;background:var(–surface2);border-radius:10px;border-left:3px solid var(–ink4);}
.city-context strong{color:var(–ink);}

.subsection-label{font-size:.6rem;font-weight:700;letter-spacing:.13em;text-transform:uppercase;color:var(–ink3);margin:14px 0 8px;display:flex;align-items:center;gap:8px;}
.subsection-label::after{content:’’;flex:1;height:1px;background:var(–border);}

/* ── VENUE ENTRY ── */
.venue-list{display:flex;flex-direction:column;gap:8px;}
.venue{background:var(–surface);border:1px solid var(–border);border-radius:11px;padding:11px 14px;}
.venue.jp{border-left:3px solid var(–jp);}
.venue.vn{border-left:3px solid var(–vn);}
.venue.warn{border-left:3px solid var(–warn);background:var(–warn-t);}
.venue-top{display:flex;align-items:baseline;gap:8px;margin-bottom:3px;}
.venue-name{font-weight:700;color:var(–ink);font-size:.84rem;}
.venue-area{font-size:.68rem;color:var(–ink3);font-weight:600;letter-spacing:.05em;}
.venue-ig{font-size:.68rem;color:var(–ink3);margin-left:auto;font-family:monospace;}
.venue-desc{font-size:.76rem;color:var(–ink2);line-height:1.55;}
.venue-desc strong{color:var(–ink);}

/* ── THRIFT ENTRY ── */
.thrift-list{display:flex;flex-direction:column;gap:8px;}
.thrift{background:var(–surface);border:1px solid var(–border);border-radius:11px;padding:11px 14px;}
.thrift-top{display:flex;align-items:baseline;gap:8px;margin-bottom:3px;}
.thrift-name{font-weight:700;color:var(–ink);font-size:.84rem;}
.thrift-area{font-size:.68rem;color:var(–ink3);font-weight:600;}
.thrift-price{font-size:.68rem;color:var(–ink3);margin-left:auto;font-variant-numeric:tabular-nums;}
.thrift-desc{font-size:.76rem;color:var(–ink2);line-height:1.55;}
.thrift-desc strong{color:var(–ink);}

/* ── VENUE LINKS ── */
.venue-links{display:flex;flex-wrap:wrap;gap:8px;margin-top:6px;}
.venue-link{font-size:.63rem;font-weight:700;letter-spacing:.05em;color:var(–ink3);
text-decoration:none;border-bottom:1px solid var(–ink4);padding-bottom:1px;
transition:color .15s,border-color .15s;}
.venue-link:hover{color:var(–ink2);border-color:var(–ink3);}
.venue-link.ig::before{content:’◈ ’;}
.venue-link.web::before{content:’⌘ ’;}
.venue-link.ra::before{content:’▸ ’;}
.venue-link.x::before{content:’✕ ‘;}
.venue-link.mail::before{content:’@ ’;}
.venue-link.tel::before{content:’☏ ’;}

/* ── FOOTER ── */
.footer{text-align:center;margin-top:60px;padding-top:24px;border-top:1px solid var(–border);}
.footer-orn{font-size:.6rem;color:var(–ink3);opacity:.35;letter-spacing:.1em;}
.footer-note{font-size:.65rem;color:var(–ink4);margin-top:6px;}
</style>

</head>
